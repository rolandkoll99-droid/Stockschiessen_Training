<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <!-- Für GitHub Pages & Tablet optimiert -->
    <meta name="theme-color" content="#1a472a">
    <meta name="description" content="Stockschießen Teamwertung – First to 2 Games mit Sprachansage und Timer. Optimiert für Tablet & GitHub Pages.">
    <title>Stockschießen | Teamwertung · Touch-Tablet optimiert</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: linear-gradient(145deg, #1a472a 0%, #0a2a1a 100%);
            min-height: 100vh;
            margin: 0;
            padding: 0;
        }

        .app-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 12px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .header-sticky {
            background: transparent;
            flex-shrink: 0;
            margin-bottom: 10px;
        }

        .container {
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            overflow: hidden;
            padding: 10px 16px 14px;
        }

        h1 {
            text-align: center;
            color: #1a472a;
            margin: 0 0 4px 0;
            font-size: clamp(18px, 4vw, 24px);
        }

        .subtitle {
            text-align: center;
            color: #6a7e6a;
            margin-bottom: 10px;
            font-size: clamp(10px, 2.5vw, 12px);
            border-bottom: 1px solid #e0e6e0;
            padding-bottom: 6px;
        }

        /* Timer-Bar - große Touch-Ziele */
        .timer-bar {
            background: #f8faf6;
            border-radius: 60px;
            padding: 8px 15px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
            box-shadow: inset 0 1px 2px rgba(0,0,0,0.02), 0 2px 5px rgba(0,0,0,0.05);
        }
        .timer-display {
            background: #1a2a1a;
            color: #eefcdd;
            font-family: 'Courier New', monospace;
            font-weight: 800;
            font-size: clamp(1.2rem, 5vw, 1.8rem);
            letter-spacing: 2px;
            padding: 8px 16px;
            border-radius: 48px;
            box-shadow: inset 0 0 0 1px #5b8c5b, 0 2px 6px rgba(0,0,0,0.2);
            min-width: 160px;
            text-align: center;
        }
        .timer-controls {
            display: flex;
            gap: 12px;
            align-items: center;
        }
        .timer-btn {
            background: white;
            border: 1px solid #bdd6b0;
            border-radius: 50px;
            padding: 8px 18px;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            transition: 0.1s;
            touch-action: manipulation;
            min-height: 48px;
            min-width: 80px;
        }
        .timer-btn:active { transform: scale(0.96); background: #eef3e8; }
        .timer-reset-btn { background: #e0ebd8; color: #1e4620; border-color: #b8cfaa; }
        .timer-pause-btn { background: #ffe6d5; color: #ad5c2a; border-color: #ffcca2; }

        .settings-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
            flex-wrap: wrap;
            background: #f8faf6;
            padding: 8px 12px;
            border-radius: 40px;
        }

        .kehren-group {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .team-name-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
        }

        .team-name-input {
            background: white;
            border: 2px solid #cddfc4;
            border-radius: 50px;
            padding: 8px 14px;
            font-size: 0.9rem;
            font-weight: 500;
            width: 140px;
            text-align: center;
            min-height: 44px;
        }

        .settings-label {
            font-size: 13px;
            font-weight: 600;
            color: #1a472a;
        }

        .kehren-select {
            background: white;
            border: 2px solid #cddfc4;
            border-radius: 50px;
            padding: 8px 14px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            min-height: 44px;
        }

        .apply-btn {
            background: #2c7a4d;
            color: white;
            border: none;
            border-radius: 50px;
            padding: 8px 20px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.1s;
            min-height: 44px;
        }
        .apply-btn:active { transform: scale(0.96); }

        .speech-toggle {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #eef3ea;
            padding: 6px 16px;
            border-radius: 50px;
            min-height: 44px;
        }
        .speech-toggle label {
            font-size: 13px;
            font-weight: 600;
            color: #1a472a;
            cursor: pointer;
        }
        .speech-toggle input {
            width: 22px;
            height: 22px;
            cursor: pointer;
        }

        .next-kehre-container {
            text-align: center;
            margin-top: 6px;
            margin-bottom: 4px;
        }
        .next-kehre-badge {
            background: #eef3ea;
            border-radius: 40px;
            padding: 8px 16px;
            display: inline-block;
            text-align: center;
            font-size: 0.9rem;
            font-weight: 700;
            color: #1a472a;
            border: 1px solid #c8dbc0;
        }
        .next-kehre-value {
            background: #2c7a4d;
            color: white;
            border-radius: 50px;
            padding: 5px 18px;
            font-weight: 800;
            font-size: 1.1rem;
            margin-left: 8px;
            display: inline-block;
        }

        .scoreboard {
            display: flex;
            gap: 14px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .team-card {
            flex: 1;
            background: #fbfdf9;
            border-radius: 24px;
            padding: 12px 12px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.08);
            min-width: 160px;
            text-align: center;
            transition: all 0.1s ease;
        }
        .team-card.teamA { border-left: 6px solid #2c7a4d; }
        .team-card.teamB { border-left: 6px solid #c0392b; }

        .team-title {
            font-size: clamp(16px, 5vw, 22px);
            font-weight: 800;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: #f4f8f0;
            border-radius: 60px;
            padding: 6px 12px;
        }

        /* Gewonnene Spiele - EXTRA GROSS für bessere Lesbarkeit auf Tablet */
        .games-won {
            background: #eef3e4;
            border-radius: 32px;
            padding: 12px 6px;
            margin: 5px 0 12px 0;
            box-shadow: inset 0 0 0 1px #d4e2ca, 0 2px 8px rgba(0,0,0,0.05);
        }
        .games-won-label {
            font-size: 14px;
            font-weight: 800;
            color: #1a472a;
            letter-spacing: 1px;
            background: #ffffffb3;
            display: inline-block;
            padding: 4px 16px;
            border-radius: 60px;
            margin-bottom: 8px;
        }
        .games-won-value {
            font-size: clamp(42px, 9vw, 72px);
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: white;
            border-radius: 60px;
            padding: 6px 12px;
            margin-top: 6px;
        }
        .games-won-number {
            background: #1a472a;
            color: white;
            padding: 6px 24px;
            border-radius: 60px;
            min-width: 100px;
            font-size: clamp(38px, 8vw, 64px);
            font-weight: 800;
            line-height: 1.2;
        }
        .games-won-number.teamA { background: #2c7a4d; }
        .games-won-number.teamB { background: #c0392b; }
        .win-indicator {
            font-size: 16px;
            font-weight: bold;
            background: #ffde9e;
            padding: 6px 14px;
            border-radius: 60px;
            color: #a15506;
            white-space: nowrap;
        }

        /* Aktuelle Runde (gut lesbar aber kleiner) */
        .current-score {
            background: #f4f7f1;
            border-radius: 50px;
            padding: 8px 8px;
            margin: 8px 0 4px;
            border: 1px solid #e2e9de;
        }
        .current-score-label {
            font-size: 11px;
            font-weight: 700;
            color: #5a6e5a;
            letter-spacing: 0.5px;
        }
        .current-score-value {
            font-size: clamp(26px, 6vw, 40px);
            font-weight: 800;
            color: #1a3a1a;
        }

        .winner-message {
            background: linear-gradient(135deg, #ffd966, #ffb347);
            border-radius: 50px;
            padding: 10px 16px;
            margin: 10px 0 0;
            text-align: center;
            font-weight: bold;
            font-size: 14px;
            color: #1e4620;
            animation: pulse 0.5s ease;
        }
        @keyframes pulse { 0% { transform: scale(0.95); opacity: 0.7; } 100% { transform: scale(1); opacity: 1; } }

        .table-scroll-area {
            flex: 1;
            overflow-y: auto;
            margin-top: 12px;
            border-radius: 20px;
            -webkit-overflow-scrolling: touch;
        }
        .table-wrapper { overflow-x: auto; border-radius: 20px; }
        .kehren-table {
            width: 100%;
            border-collapse: collapse;
            background: white;
            min-width: 500px;
            border-radius: 20px;
        }
        .kehren-table th, .kehren-table td {
            border: 1px solid #e2e8e2;
            padding: 14px 8px;
            text-align: center;
            vertical-align: middle;
        }
        .kehren-table th {
            background: #eef3ea;
            font-weight: 800;
            color: #1a472a;
            font-size: clamp(13px, 3vw, 15px);
            position: sticky;
            top: 0;
            z-index: 10;
            padding: 12px 6px;
        }
        .kehren-table td:first-child {
            font-weight: 800;
            background: #fafcf8;
            width: 65px;
            font-size: 1rem;
        }
        .next-kehre-highlight td:first-child {
            background: #ffe6b3;
            font-weight: 800;
            border-left: 4px solid #ffa500;
        }
        .next-kehre-highlight td:not(:first-child) {
            background: #fff2df;
        }

        /* Große Touch-Bereiche für Punkte-Buttons (Tablet optimiert) */
        .punktgruppe {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 10px;
            align-items: center;
        }
        .punkt-btn-zahl {
            min-width: 58px;
            min-height: 58px;
            background: white;
            border: 2px solid #cddfc4;
            border-radius: 50px;
            padding: 12px 0;
            font-weight: 800;
            font-size: 1.3rem;
            cursor: pointer;
            transition: all 0.1s ease;
            color: #1e4620;
            touch-action: manipulation;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .punkt-btn-zahl:active { transform: scale(0.94); background: #e9f3e3; border-color: #2c7a4d; }
        .aktiver-wert {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #1a472a;
            color: white;
            padding: 10px 18px;
            border-radius: 50px;
            font-size: 1.3rem;
            font-weight: bold;
            min-width: 60px;
            min-height: 58px;
        }
        .loesch-icon {
            background: #fef5f3;
            border: 2px solid #f0cec6;
            border-radius: 50px;
            font-size: 1.3rem;
            cursor: pointer;
            color: #b85c4a;
            padding: 10px 16px;
            min-width: 60px;
            min-height: 58px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .loesch-icon:active { background: #fbeae7; transform: scale(0.94); }

        .action-buttons {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-top: 16px;
            flex-wrap: wrap;
            flex-shrink: 0;
        }
        .action-btn {
            padding: 12px 18px;
            font-size: 0.9rem;
            font-weight: 700;
            border: none;
            border-radius: 60px;
            cursor: pointer;
            transition: 0.1s;
            touch-action: manipulation;
            min-width: 120px;
            min-height: 52px;
        }
        .action-btn.win-game { background: #ffd966; color: #1e4620; }
        .action-btn.reset-round { background: #eef2e8; color: #1e4620; }
        .action-btn.newgame { background: #1a472a; color: white; }
        .action-btn.reset-total { background: #ffe6e2; color: #b33a2a; }
        .action-btn.export-excel { background: #2c7a4d; color: white; }
        .action-btn.export-pdf { background: #c0392b; color: white; }
        .action-btn:active { transform: scale(0.97); }

        footer {
            text-align: center;
            margin-top: 10px;
            font-size: 10px;
            color: #8a9a88;
            flex-shrink: 0;
            padding-bottom: 4px;
        }

        .toast-msg {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background-color: #1a472a;
            color: white;
            padding: 12px 24px;
            border-radius: 60px;
            font-size: 16px;
            z-index: 2000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            pointer-events: none;
            text-align: center;
            max-width: 90vw;
            font-weight: 500;
        }

        .modal-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.75);
            display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px);
        }
        .modal-dialog {
            background: white; border-radius: 40px; max-width: 400px; width: 85%; padding: 24px 20px 20px; text-align: center;
            animation: fadeInUp 0.2s ease;
        }
        .modal-dialog h3 { font-size: 1.5rem; margin: 0 0 12px; color: #1a472a; }
        .modal-dialog p { font-size: 1rem; color: #3a5a3a; margin-bottom: 24px; }
        .modal-buttons { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
        .modal-btn {
            padding: 12px 24px;
            border: none;
            border-radius: 60px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            min-width: 110px;
            min-height: 50px;
        }
        .modal-btn.confirm { background: #c0392b; color: white; }
        .modal-btn.cancel { background: #e9ecef; color: #2c3e2c; }
        .modal-btn:active { transform: scale(0.96); }
        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        /* Sperrmodus */
        body.game-finished .win-game,
        body.game-finished .reset-round,
        body.game-finished .punkt-btn-zahl,
        body.game-finished .loesch-icon {
            opacity: 0.5;
            pointer-events: none;
        }
        body.game-finished .action-btn.win-game,
        body.game-finished .action-btn.reset-round {
            opacity: 0.5;
            pointer-events: none;
        }
        .game-lock-notice {
            font-size: 12px;
            background: #f0e6d2;
            border-radius: 40px;
            padding: 4px 16px;
            display: inline-block;
            margin-top: 8px;
            color: #b1621a;
            font-weight: bold;
        }
        .edge-hint {
            background: #eef3ea;
            border-radius: 30px;
            font-size: 10px;
            text-align: center;
            padding: 5px 12px;
            margin-bottom: 8px;
            color: #2c5e2c;
        }

        @media (max-width: 700px) {
            .punkt-btn-zahl, .aktiver-wert, .loesch-icon { min-width: 50px; min-height: 50px; font-size: 1.1rem; }
            .action-btn { min-width: 100px; font-size: 0.8rem; }
            .team-name-input { width: 120px; font-size: 0.8rem; }
            .games-won-number { min-width: 75px; font-size: 32px; }
        }
        @media print {
            .settings-bar, .action-buttons, footer, .apply-btn, .loesch-icon, .punkt-btn-zahl, .win-indicator, .winner-message, .action-btn, .kehren-select, .team-name-group, .settings-label, .next-kehre-container, .speech-toggle, .game-lock-notice, .edge-hint, .timer-bar {
                display: none !important;
            }
            body, .app-container, .container, .scoreboard, .team-card, .table-scroll-area { background: white; padding: 0; margin: 0; overflow: visible; height: auto; }
            .kehren-table th, .kehren-table td { border: 1px solid #000; }
        }
    </style>
</head>
<body>
<div class="app-container">
    <div class="header-sticky">
        <div class="container">
            <h1>🥌 Stockschießen Wertung 🥌</h1>
            <div class="subtitle">1–4 Punkte pro Kehre · First to 2 Games (Sieg nach 2 Spielen)</div>
            <div class="edge-hint">📱 Tablet-optimiert · Cloud-fähig (GitHub Pages) · Sprachansage & Spielzeituhr</div>
            
            <div class="timer-bar">
                <span class="timer-label">⏱️ SPIELZEIT</span>
                <div class="timer-display" id="timerDisplay">00:00:00</div>
                <div class="timer-controls">
                    <button class="timer-btn timer-reset-btn" id="timerResetBtn">🔄 Reset</button>
                    <button class="timer-btn timer-pause-btn" id="timerPauseBtn">⏸️ Pause</button>
                </div>
            </div>

            <div class="settings-bar">
                <div class="kehren-group">
                    <span class="settings-label">⚙️ Kehren:</span>
                    <select id="kehrenSelect" class="kehren-select">
                        <option value="4">4 Kehren</option>
                        <option value="6" selected>6 Kehren</option>
                        <option value="8">8 Kehren</option>
                        <option value="10">10 Kehren</option>
                        <option value="12">12 Kehren</option>
                    </select>
                    <button id="applyKehrenBtn" class="apply-btn">Übernehmen</button>
                </div>
                <div class="team-name-group">
                    <input type="text" id="teamANameInput" class="team-name-input" value="Mannschaft W" maxlength="20">
                    <span style="color:#2c7a4d; font-weight:bold;">vs</span>
                    <input type="text" id="teamBNameInput" class="team-name-input" value="Mannschaft E" maxlength="20">
                </div>
                <div class="speech-toggle">
                    <input type="checkbox" id="speechEnabled" checked>
                    <label for="speechEnabled">🔊 Sprachansage</label>
                </div>
            </div>

            <div class="scoreboard">
                <div class="team-card teamA">
                    <div class="team-title" id="teamATitle">🥌 Mannschaft W</div>
                    <div class="games-won">
                        <div class="games-won-label">🏆 SPIELE GEWONNEN 🏆</div>
                        <div class="games-won-value">
                            <span class="games-won-number teamA" id="gamesWonTeamA">0</span>
                            <span class="win-indicator" id="winnerIndicatorA"></span>
                        </div>
                    </div>
                    <div class="current-score">
                        <div class="current-score-label">AKTUELLE RUNDE</div>
                        <div class="current-score-value" id="currentTeamA">0</div>
                    </div>
                </div>
                <div class="team-card teamB">
                    <div class="team-title" id="teamBTitle">🥌 Mannschaft E</div>
                    <div class="games-won">
                        <div class="games-won-label">🏆 SPIELE GEWONNEN 🏆</div>
                        <div class="games-won-value">
                            <span class="games-won-number teamB" id="gamesWonTeamB">0</span>
                            <span class="win-indicator" id="winnerIndicatorB"></span>
                        </div>
                    </div>
                    <div class="current-score">
                        <div class="current-score-label">AKTUELLE RUNDE</div>
                        <div class="current-score-value" id="currentTeamB">0</div>
                    </div>
                </div>
            </div>
            
            <div class="next-kehre-container">
                <div class="next-kehre-badge">
                    🎯 Nächste Kehre <span class="next-kehre-value" id="nextKehreNumber">1</span>
                </div>
            </div>
            
            <div id="winnerMessage" style="display: none;"></div>
            <div id="gameLockNotice" class="game-lock-notice" style="display: none;">🔒 Spiel beendet – Sieger steht! (Neues Spiel starten)</div>
        </div>
    </div>

    <div class="table-scroll-area">
        <div class="table-wrapper">
            <table class="kehren-table" id="scoreTable"></table>
        </div>
    </div>

    <div class="action-buttons">
        <button class="action-btn win-game" id="winGameBtn">🏆 Spiel gewinnen</button>
        <button class="action-btn reset-round" id="resetRoundBtn">🔄 Runde löschen</button>
        <button class="action-btn newgame" id="newGameBtn">✨ Neues Spiel</button>
        <button class="action-btn reset-total" id="resetTotalBtn">🗑️ Gesamtwertung</button>
        <button class="action-btn export-excel" id="exportExcelBtn">📎 Excel (CSV)</button>
        <button class="action-btn export-pdf" id="exportPdfBtn">🖨️ PDF Drucken</button>
    </div>
    <footer>👆 Punkte (1-4) antippen – "Spiel gewinnen" wertet die Runde | 🏆 Wer zuerst 2 Spiele gewinnt, ist Gesamtsieger | 🎤 Sprachansage aktivierbar</footer>
</div>

<script>
    // ---------- TIMER ----------
    let gameStartTimestamp = null;
    let timerInterval = null;
    let isTimerRunning = true;
    const timerDisplaySpan = document.getElementById('timerDisplay');
    const timerResetBtn = document.getElementById('timerResetBtn');
    const timerPauseBtn = document.getElementById('timerPauseBtn');

    function updateTimerUI() {
        if (!gameStartTimestamp) { timerDisplaySpan.textContent = "00:00:00"; return; }
        const elapsed = Date.now() - gameStartTimestamp;
        if (elapsed < 0) return;
        const totalSec = Math.floor(elapsed / 1000);
        const hours = Math.floor(totalSec / 3600);
        const mins = Math.floor((totalSec % 3600) / 60);
        const secs = totalSec % 60;
        timerDisplaySpan.textContent = `${hours.toString().padStart(2,'0')}:${mins.toString().padStart(2,'0')}:${secs.toString().padStart(2,'0')}`;
    }
    function startTimerInterval() { if (!timerInterval) timerInterval = setInterval(() => { if (isTimerRunning && gameStartTimestamp) updateTimerUI(); }, 200); }
    function stopTimerInterval() { if (timerInterval) { clearInterval(timerInterval); timerInterval = null; } }
    function fullTimerReset() { gameStartTimestamp = Date.now(); isTimerRunning = true; window._pausedElapsed = null; updateTimerUI(); timerPauseBtn.textContent = "⏸️ Pause"; startTimerInterval(); }
    function pauseTimer() {
        if (!gameStartTimestamp && !window._pausedElapsed) return;
        if (isTimerRunning) {
            window._pausedElapsed = Date.now() - gameStartTimestamp;
            gameStartTimestamp = null;
            isTimerRunning = false;
            updateTimerUI();
            timerPauseBtn.textContent = "▶️ Start";
        } else {
            gameStartTimestamp = Date.now() - (window._pausedElapsed || 0);
            isTimerRunning = true;
            window._pausedElapsed = null;
            updateTimerUI();
            timerPauseBtn.textContent = "⏸️ Pause";
            startTimerInterval();
        }
    }
    function resetAndStartTimerOnNewGame() { stopTimerInterval(); gameStartTimestamp = Date.now(); isTimerRunning = true; window._pausedElapsed = null; updateTimerUI(); startTimerInterval(); timerPauseBtn.textContent = "⏸️ Pause"; }
    timerResetBtn.addEventListener('click', () => { fullTimerReset(); showToast("⏱️ Spielzeit zurückgesetzt", 1500); });
    timerPauseBtn.addEventListener('click', () => { pauseTimer(); showToast(isTimerRunning ? "⏵ Timer läuft" : "⏸ Timer pausiert", 1000); });

    // ---------- KERNLOGIK ----------
    let anzahlKehren = 6;
    let teamAPunkte = [], teamBPunkte = [];
    let gamesWonTeamA = 0, gamesWonTeamB = 0;
    let gameWinnerAnnounced = false, overallWinnerDeclared = false;
    let teamAName = "Mannschaft W", teamBName = "Mannschaft E";
    let speechEnabled = true;

    const teamATitleSpan = document.getElementById('teamATitle');
    const teamBTitleSpan = document.getElementById('teamBTitle');
    const currentTeamASpan = document.getElementById('currentTeamA');
    const currentTeamBSpan = document.getElementById('currentTeamB');
    const gamesWonTeamASpan = document.getElementById('gamesWonTeamA');
    const gamesWonTeamBSpan = document.getElementById('gamesWonTeamB');
    const winnerIndicatorA = document.getElementById('winnerIndicatorA');
    const winnerIndicatorB = document.getElementById('winnerIndicatorB');
    const winnerMessageDiv = document.getElementById('winnerMessage');
    const gameLockNoticeDiv = document.getElementById('gameLockNotice');
    const nextKehreSpan = document.getElementById('nextKehreNumber');
    const speechCheckbox = document.getElementById('speechEnabled');

    function speakText(text) { if (!speechEnabled) return; if ('speechSynthesis' in window) { try { window.speechSynthesis.cancel(); const u = new SpeechSynthesisUtterance(text); u.lang = 'de-DE'; u.rate = 0.9; window.speechSynthesis.speak(u); } catch(e) {} } }
    function showToast(msg, dur=3000) { let t=document.getElementById('dynamicToast'); if(!t){ t=document.createElement('div'); t.id='dynamicToast'; t.className='toast-msg'; document.body.appendChild(t); } t.textContent=msg; t.style.display='block'; setTimeout(()=>{ t.style.display='none'; }, dur); }
    function berechneSumme(arr) { return arr.reduce((a,b)=>a+b,0); }
    function updateGameLockState() { if(overallWinnerDeclared) { document.body.classList.add('game-finished'); gameLockNoticeDiv.style.display='inline-block'; } else { document.body.classList.remove('game-finished'); gameLockNoticeDiv.style.display='none'; } }
    
    function checkForOverallWinner() {
        if(overallWinnerDeclared) return true;
        if(gamesWonTeamA>=2) {
            overallWinnerDeclared=true; gameWinnerAnnounced=true;
            winnerMessageDiv.style.display='block'; winnerMessageDiv.className='winner-message';
            winnerMessageDiv.innerHTML = `🏆🥌🏆 ${teamAName} hat den Gesamtsieg errungen! (2 Spiele gewonnen) 🏆🥌🏆`;
            speakText(`Sieger ist die Mannschaft ${teamAName}. ${teamAName} hat zwei Spiele gewonnen und den Gesamtsieg errungen.`);
            updateTotals(); updateGameLockState();
            return true;
        } else if(gamesWonTeamB>=2) {
            overallWinnerDeclared=true; gameWinnerAnnounced=true;
            winnerMessageDiv.style.display='block'; winnerMessageDiv.className='winner-message';
            winnerMessageDiv.innerHTML = `🏆🥌🏆 ${teamBName} hat den Gesamtsieg errungen! (2 Spiele gewonnen) 🏆🥌🏆`;
            speakText(`Sieger ist die Mannschaft ${teamBName}. ${teamBName} hat zwei Spiele gewonnen und den Gesamtsieg errungen.`);
            updateTotals(); updateGameLockState();
            return true;
        }
        return false;
    }

    function getNextKehreIndex() { for(let i=0;i<anzahlKehren;i++) if((teamAPunkte[i]||0)===0 && (teamBPunkte[i]||0)===0) return i; return -1; }
    function updateNextKehreDisplay() { if(overallWinnerDeclared) { nextKehreSpan.textContent="🏆"; highlightNextKehreRow(-1); return; } const n=getNextKehreIndex(); if(n!==-1) { nextKehreSpan.textContent=(n+1).toString(); highlightNextKehreRow(n); } else { nextKehreSpan.textContent="✓"; highlightNextKehreRow(-1); } }
    function highlightNextKehreRow(idx) { const tbody=document.querySelector('#scoreTable tbody'); if(!tbody) return; Array.from(tbody.children).forEach((row,i)=>{ row.classList.toggle('next-kehre-highlight', i===idx); }); }

    function updateTotals() {
        currentTeamASpan.textContent = berechneSumme(teamAPunkte);
        currentTeamBSpan.textContent = berechneSumme(teamBPunkte);
        gamesWonTeamASpan.textContent = gamesWonTeamA;
        gamesWonTeamBSpan.textContent = gamesWonTeamB;
        if(gamesWonTeamA>=2) winnerIndicatorA.innerHTML='🏆 GESAMTSIEGER 🏆';
        else if(gamesWonTeamA===1) winnerIndicatorA.innerHTML='⚡ 1 Spiel';
        else winnerIndicatorA.innerHTML='';
        if(gamesWonTeamB>=2) winnerIndicatorB.innerHTML='🏆 GESAMTSIEGER 🏆';
        else if(gamesWonTeamB===1) winnerIndicatorB.innerHTML='⚡ 1 Spiel';
        else winnerIndicatorB.innerHTML='';
        if(!overallWinnerDeclared && gameWinnerAnnounced && gamesWonTeamA<2 && gamesWonTeamB<2) { gameWinnerAnnounced=false; winnerMessageDiv.style.display='none'; winnerMessageDiv.innerHTML=''; }
        updateNextKehreDisplay();
    }

    function setPoints(team, kehre, wert) { if(overallWinnerDeclared) { showToast("Spiel beendet!",1200); return; } if(team==='A') teamAPunkte[kehre]=wert; else teamBPunkte[kehre]=wert; renderTable(); if(wert>=1 && wert<=4) { const tn=team==='A'?teamAName:teamBName; speakText(`${tn} erzielt bei Kehre ${kehre+1} ${wert===1?"einen Punkt":wert+" Punkte"}.`); showToast(`${tn} +${wert}`,1800); } }
    function deleteKehre(team, kehre) { if(overallWinnerDeclared) { showToast("Spiel beendet",1000); return; } if(team==='A') teamAPunkte[kehre]=0; else teamBPunkte[kehre]=0; renderTable(); }
    function resetCurrentRound() { if(overallWinnerDeclared) { showToast("Spiel beendet!",1000); return; } for(let i=0;i<anzahlKehren;i++) { teamAPunkte[i]=0; teamBPunkte[i]=0; } renderTable(); }

    function winGame() { if(overallWinnerDeclared) { showToast("Spiel bereits entschieden!",1500); return; }
        const sumA=berechneSumme(teamAPunkte), sumB=berechneSumme(teamBPunkte);
        if(sumA===0 && sumB===0) { showConfirmDialog('Keine Punkte','Bitte zuerst Punkte vergeben.',()=>{}); return; }
        if(sumA===sumB) showWinnerSelection();
        else { const winner=sumA>sumB?'A':'B'; const winnerName=winner==='A'?teamAName:teamBName; showConfirmDialog('Spiel gewonnen',`${winnerName} gewinnt (${sumA}:${sumB}). Bestätigen?`,()=>{ if(winner==='A') gamesWonTeamA++; else gamesWonTeamB++; resetCurrentRound(); updateTotals(); checkForOverallWinner(); }); }
    }
    function showWinnerSelection() { const sumA=berechneSumme(teamAPunkte), sumB=berechneSumme(teamBPunkte); const ov=document.createElement('div'); ov.className='modal-overlay'; ov.innerHTML=`<div class="modal-dialog"><h3>🤝 Unentschieden!</h3><p>Runde ${sumA}:${sumB}.<br>Wer gewinnt das Spiel?</p><div class="modal-buttons"><button class="modal-btn confirm" id="winnerTeamA">🥌 ${teamAName}</button><button class="modal-btn confirm" id="winnerTeamB">🥌 ${teamBName}</button><button class="modal-btn cancel" id="modalCancel">Abbrechen</button></div></div>`; document.body.appendChild(ov); const close=()=>ov.remove(); ov.querySelector('#winnerTeamA')?.addEventListener('click',()=>{ if(!overallWinnerDeclared) gamesWonTeamA++; resetCurrentRound(); updateTotals(); checkForOverallWinner(); close(); }); ov.querySelector('#winnerTeamB')?.addEventListener('click',()=>{ if(!overallWinnerDeclared) gamesWonTeamB++; resetCurrentRound(); updateTotals(); checkForOverallWinner(); close(); }); ov.querySelector('#modalCancel')?.addEventListener('click',close); ov.addEventListener('click',e=>{if(e.target===ov) close();}); }
    function resetTotalScore() { showConfirmDialog('Gesamtwertung löschen?','Alle gewonnenen Spiele und Siegstatus zurücksetzen.',()=>{ gamesWonTeamA=0; gamesWonTeamB=0; overallWinnerDeclared=false; gameWinnerAnnounced=false; winnerMessageDiv.style.display='none'; winnerMessageDiv.innerHTML=''; updateTotals(); updateGameLockState(); resetAndStartTimerOnNewGame(); }); }
    function newGame() { showConfirmDialog('Neues Spiel starten?','Kompletter Reset: Punkte, Spiele, Timer.',()=>{ for(let i=0;i<anzahlKehren;i++) { teamAPunkte[i]=0; teamBPunkte[i]=0; } gamesWonTeamA=0; gamesWonTeamB=0; overallWinnerDeclared=false; gameWinnerAnnounced=false; winnerMessageDiv.style.display='none'; winnerMessageDiv.innerHTML=''; renderTable(); updateTotals(); updateGameLockState(); resetAndStartTimerOnNewGame(); }); }
    function changeKehrenAnzahl(neu) { const newA=new Array(neu).fill(0), newB=new Array(neu).fill(0); for(let i=0;i<Math.min(teamAPunkte.length,neu);i++){ newA[i]=teamAPunkte[i]; newB[i]=teamBPunkte[i]; } teamAPunkte=newA; teamBPunkte=newB; anzahlKehren=neu; renderTable(); updateTotals(); }
    function updateTeamNameUI() { teamATitleSpan.innerHTML=`🥌 ${teamAName}`; teamBTitleSpan.innerHTML=`🥌 ${teamBName}`; renderTable(); updateTotals(); }
    
    function renderTable() {
        const tbl=document.getElementById('scoreTable'); tbl.innerHTML='';
        const thead=document.createElement('thead'); const tr=document.createElement('tr'); tr.appendChild(createTh('Kehre')); tr.appendChild(createTh(`🥌 ${teamAName}`)); tr.appendChild(createTh(`🥌 ${teamBName}`)); thead.appendChild(tr); tbl.appendChild(thead);
        const tbody=document.createElement('tbody');
        for(let i=0;i<anzahlKehren;i++){
            const row=document.createElement('tr');
            const tdK=document.createElement('td'); tdK.textContent=(i+1).toString(); row.appendChild(tdK);
            const tdA=document.createElement('td'); const grpA=document.createElement('div'); grpA.className='punktgruppe';
            for(let p=1;p<=4;p++){ const btn=document.createElement('button'); btn.textContent=p; btn.classList.add('punkt-btn-zahl'); btn.addEventListener('click',(e)=>{e.stopPropagation(); setPoints('A',i,p);}); grpA.appendChild(btn); }
            const valA=document.createElement('span'); valA.className='aktiver-wert'; valA.textContent=teamAPunkte[i]||0;
            const delA=document.createElement('button'); delA.textContent='🗑️'; delA.classList.add('loesch-icon'); delA.addEventListener('click',(e)=>{e.stopPropagation(); deleteKehre('A',i);});
            grpA.appendChild(valA); grpA.appendChild(delA); tdA.appendChild(grpA); row.appendChild(tdA);
            const tdB=document.createElement('td'); const grpB=document.createElement('div'); grpB.className='punktgruppe';
            for(let p=1;p<=4;p++){ const btn=document.createElement('button'); btn.textContent=p; btn.classList.add('punkt-btn-zahl'); btn.addEventListener('click',(e)=>{e.stopPropagation(); setPoints('B',i,p);}); grpB.appendChild(btn); }
            const valB=document.createElement('span'); valB.className='aktiver-wert'; valB.textContent=teamBPunkte[i]||0;
            const delB=document.createElement('button'); delB.textContent='🗑️'; delB.classList.add('loesch-icon'); delB.addEventListener('click',(e)=>{e.stopPropagation(); deleteKehre('B',i);});
            grpB.appendChild(valB); grpB.appendChild(delB); tdB.appendChild(grpB); row.appendChild(tdB);
            tbody.appendChild(row);
        }
        tbl.appendChild(tbody); updateTotals();
    }
    function createTh(txt){ const th=document.createElement('th'); th.textContent=txt; return th; }
    function showConfirmDialog(title,msg,onConfirm){ const ov=document.createElement('div'); ov.className='modal-overlay'; ov.innerHTML=`<div class="modal-dialog"><h3>${title}</h3><p>${msg}</p><div class="modal-buttons"><button class="modal-btn cancel" id="modalCancel">Abbrechen</button><button class="modal-btn confirm" id="modalConfirm">Ja</button></div></div>`; document.body.appendChild(ov); const close=()=>ov.remove(); ov.querySelector('#modalCancel')?.addEventListener('click',close); ov.querySelector('#modalConfirm')?.addEventListener('click',()=>{ close(); if(onConfirm) onConfirm(); }); ov.addEventListener('click',e=>{if(e.target===ov) close();}); }
    function exportCSV(){ let rows=[`Kehre;${teamAName};${teamBName}`]; for(let i=0;i<anzahlKehren;i++) rows.push(`${i+1};${teamAPunkte[i]};${teamBPunkte[i]}`); rows.push(`Summe;${berechneSumme(teamAPunkte)};${berechneSumme(teamBPunkte)}`,`Gewonnene Spiele;${gamesWonTeamA};${gamesWonTeamB}`); const blob=new Blob(["\uFEFF"+rows.join('\n')],{type:"text/csv;charset=utf-8"}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download="stockschiessen.csv"; a.click(); URL.revokeObjectURL(a.href); }
    function bindEvents(){
        document.getElementById('winGameBtn').addEventListener('click',winGame);
        document.getElementById('resetRoundBtn').addEventListener('click',resetCurrentRound);
        document.getElementById('newGameBtn').addEventListener('click',newGame);
        document.getElementById('resetTotalBtn').addEventListener('click',resetTotalScore);
        document.getElementById('exportExcelBtn').addEventListener('click',exportCSV);
        document.getElementById('exportPdfBtn').addEventListener('click',()=>window.print());
        document.getElementById('applyKehrenBtn').addEventListener('click',()=>{ const neu=parseInt(document.getElementById('kehrenSelect').value,10); if(neu!==anzahlKehren) showConfirmDialog('Kehren ändern',`Auf ${neu} Kehren umstellen?`,()=>changeKehrenAnzahl(neu)); });
        document.getElementById('teamANameInput').addEventListener('input',e=>{ teamAName=e.target.value.trim()||"Team A"; updateTeamNameUI(); });
        document.getElementById('teamBNameInput').addEventListener('input',e=>{ teamBName=e.target.value.trim()||"Team B"; updateTeamNameUI(); });
        speechCheckbox.addEventListener('change',e=>{ speechEnabled=e.target.checked; });
    }
    function init(){
        anzahlKehren=6; teamAPunkte=new Array(6).fill(0); teamBPunkte=new Array(6).fill(0);
        teamAName="Mannschaft W"; teamBName="Mannschaft E";
        document.getElementById('teamANameInput').value=teamAName;
        document.getElementById('teamBNameInput').value=teamBName;
        gamesWonTeamA=0; gamesWonTeamB=0; overallWinnerDeclared=false; gameWinnerAnnounced=false;
        renderTable(); updateTeamNameUI(); bindEvents(); updateGameLockState();
        gameStartTimestamp=Date.now(); isTimerRunning=true; updateTimerUI(); startTimerInterval(); timerPauseBtn.textContent="⏸️ Pause";
    }
    init();
</script>
</body>
</html>